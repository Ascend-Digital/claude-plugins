{
  "mcpServers": {
    "github-readonly": {
      "command": "github-mcp-server",
      "args": [
        "stdio",
        "--read-only",
        "--toolsets=repos,issues,pull_requests"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "allowedTools": [
        "get_file_contents",
        "search_repositories",
        "search_code",
        "list_branches",
        "list_commits",
        "get_commit",
        "get_repository",
        "list_repository_files",
        "get_issue",
        "list_issues",
        "search_issues",
        "get_issue_comments",
        "get_pull_request",
        "list_pull_requests",
        "get_pull_request_files",
        "get_pull_request_diff",
        "get_pull_request_comments",
        "get_pull_request_reviews",
        "list_tags",
        "list_releases",
        "get_release"
      ]
    },
    "ascend-wiki": {
      "type": "http",
      "url": "https://wiki.seeiton.dev/mcp",
      "headers": {
        "Authorization": "Bearer ${ASCEND_WIKI_MCP_TOKEN}"
      },
      "allowedTools": [
        "search_wiki",
        "get_wiki_structure",
        "read_page",
        "get_page_summary",
        "find_related_pages",
        "list_projects",
        "read_section"
      ]
    }
  }
}